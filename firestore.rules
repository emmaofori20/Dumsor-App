rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /areas/{areaId} {
      allow read: if true;
      allow write: if false;
    }

    match /schedules/{scheduleId} {
      allow read: if true;
      allow write: if false;
    }

    match /reports/{reportId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly([
        'areaId', 'areaName', 'group', 'status', 'comment', 'createdAt', 'deviceId'
      ])
      && request.resource.data.status in ['ON', 'OFF']
      && request.resource.data.areaId is string
      && request.resource.data.areaName is string
      && request.resource.data.group in ['A', 'B', 'C']
      && request.resource.data.deviceId is string
      && request.resource.data.comment is string
      && request.resource.data.comment.size() <= 280;
    }

    match /missingAreas/{missingAreaId} {
      allow read: if false;
      allow create: if request.resource.data.keys().hasOnly([
        'query', 'createdAt', 'deviceId'
      ])
      && request.resource.data.query is string
      && request.resource.data.query.size() > 1
      && request.resource.data.query.size() <= 120
      && request.resource.data.deviceId is string;
    }
  }
}
